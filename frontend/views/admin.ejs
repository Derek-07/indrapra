<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin CMS | Indraprastha</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { brandTeal: '#1F363C', brandGold: '#C79F39', darkBg: '#0a0a0a', darkSurface: '#171717' },
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
                }
            }
        }
        
        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(t => t.classList.add('hidden'));
            document.querySelectorAll('.tab-btn').forEach(t => {
                t.classList.remove('bg-brandTeal', 'text-white');
                t.classList.add('bg-gray-200', 'text-gray-700');
            });
            document.getElementById(tabId).classList.remove('hidden');
            document.getElementById('btn-' + tabId).classList.remove('bg-gray-200', 'text-gray-700');
            document.getElementById('btn-' + tabId).classList.add('bg-brandTeal', 'text-white');
        }
    </script>
</head>
<body class="bg-gray-100 font-sans text-gray-800">

    <!-- Navbar -->
    <nav class="bg-brandTeal text-white p-4 shadow-md flex justify-between items-center sticky top-0 z-50">
        <div class="flex items-center gap-3">
            <div class="bg-brandGold text-brandTeal font-bold px-2 py-1 rounded">ADMIN</div>
            <h1 class="text-xl font-bold tracking-widest uppercase hidden sm:block">Indraprastha CMS</h1>
        </div>
        <div class="flex items-center gap-4">
            <a href="/" target="_blank" class="text-sm font-semibold hover:text-brandGold transition-colors">Live Site &rarr;</a>
            <a href="/api/logout" class="text-sm font-semibold bg-red-500/20 text-red-100 px-4 py-2 rounded-lg hover:bg-red-500/40 transition-colors">Logout</a>
        </div>
    </nav>

    <div class="container mx-auto p-4 md:p-6">
        <!-- Tabs -->
        <div class="flex flex-wrap gap-2 md:gap-4 mb-8 sticky top-[72px] bg-gray-100 py-2 z-40">
            <button id="btn-tab-users" onclick="switchTab('tab-users')" class="tab-btn bg-brandTeal text-white font-bold px-4 md:px-6 py-2 md:py-3 rounded-lg shadow transition-colors text-sm md:text-base">Users & Assign</button>
            <button id="btn-tab-projects" onclick="switchTab('tab-projects')" class="tab-btn bg-gray-200 text-gray-700 font-bold px-4 md:px-6 py-2 md:py-3 rounded-lg shadow transition-colors text-sm md:text-base">Projects Portfolio</button>
            <button id="btn-tab-content" onclick="switchTab('tab-content')" class="tab-btn bg-gray-200 text-gray-700 font-bold px-4 md:px-6 py-2 md:py-3 rounded-lg shadow transition-colors text-sm md:text-base">Global Content</button>
            <button id="btn-tab-blogs" onclick="switchTab('tab-blogs')" class="tab-btn bg-gray-200 text-gray-700 font-bold px-4 md:px-6 py-2 md:py-3 rounded-lg shadow transition-colors text-sm md:text-base">Blogs</button>
            <button id="btn-tab-testimonials" onclick="switchTab('tab-testimonials')" class="tab-btn bg-gray-200 text-gray-700 font-bold px-4 md:px-6 py-2 md:py-3 rounded-lg shadow transition-colors text-sm md:text-base">Testimonials</button>
        </div>

        <!-- Tab: Users -->
        <div id="tab-users" class="tab-content">
            <div class="bg-white rounded-xl shadow p-6">
                <h2 class="text-2xl font-bold mb-2">User & Client Management</h2>
                <p class="text-gray-500 mb-8">Assign specific projects to signed-up users.</p>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse min-w-full">
                        <thead>
                            <tr class="bg-gray-50 border-b border-gray-200">
                                <th class="p-4 font-bold text-gray-700">Email</th>
                                <th class="p-4 font-bold text-gray-700">Status</th>
                                <th class="p-4 font-bold text-gray-700">Assigned Project</th>
                                <th class="p-4 font-bold text-gray-700">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (users.length === 0) { %>
                                <tr><td colspan="4" class="p-4 text-center text-gray-500 italic">No users found.</td></tr>
                            <% } %>
                            <% users.forEach(user => { %>
                                <tr class="border-b border-gray-100 hover:bg-gray-50">
                                    <td class="p-4 font-semibold"><%= user.email %></td>
                                    <td class="p-4"><span class="text-xs font-bold px-3 py-1 rounded-full bg-green-100 text-green-800">Active</span></td>
                                    <td class="p-4">
                                        <form action="/admin/users/assign" method="POST" class="flex flex-col sm:flex-row gap-2">
                                            <input type="hidden" name="userId" value="<%= user.id %>">
                                            <select name="projectId" class="border rounded px-3 py-2 w-full focus:ring-2 focus:ring-brandTeal outline-none text-sm">
                                                <option value="">-- No Project Assigned --</option>
                                                <% projects.forEach(proj => { %>
                                                    <option value="<%= proj.id %>" <%= (user.assignedProject && user.assignedProject.id === proj.id) ? 'selected' : '' %>><%= proj.title %> - <%= proj.clientName %></option>
                                                <% }) %>
                                            </select>
                                            <button type="submit" class="bg-brandTeal text-white px-4 py-2 rounded text-sm font-bold hover:bg-brandGold transition-colors">Assign</button>
                                        </form>
                                    </td>
                                    <td class="p-4"><span class="text-xs text-gray-400">Managed</span></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Tab: Projects -->
        <div id="tab-projects" class="tab-content hidden space-y-8">
            <div class="bg-white rounded-xl shadow p-6 border-l-4 border-brandTeal">
                <h2 class="text-2xl font-bold mb-2">Create New Project</h2>
                <p class="text-gray-500 mb-6">Create a project here. It will show up on the public Projects page AND can be assigned to a Client Dashboard.</p>
                <form action="/admin/projects/new" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div><label class="block text-sm font-bold text-gray-700 mb-2">Project Title</label><input type="text" name="title" required placeholder="Luxury Villa 104" class="w-full border px-4 py-3 rounded-lg outline-none"></div>
                    <div><label class="block text-sm font-bold text-gray-700 mb-2">Client Name</label><input type="text" name="clientName" required placeholder="Mr. Sharma" class="w-full border px-4 py-3 rounded-lg outline-none"></div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Status</label>
                        <select name="status" class="w-full border px-4 py-3 rounded-lg outline-none">
                            <option value="Planning">Planning & Design</option>
                            <option value="Construction">Under Construction</option>
                            <option value="Completed">Completed</option>
                        </select>
                    </div>
                    <div><label class="block text-sm font-bold text-gray-700 mb-2">Progress (%)</label><input type="number" name="progress" min="0" max="100" value="0" class="w-full border px-4 py-3 rounded-lg outline-none"></div>
                    <div><label class="block text-sm font-bold text-gray-700 mb-2">Manager Name</label><input type="text" name="managerName" value="Admin Team" class="w-full border px-4 py-3 rounded-lg outline-none"></div>
                    <div><label class="block text-sm font-bold text-gray-700 mb-2">Image URL (Optional)</label><input type="url" name="imageUrl" placeholder="https://example.com/image.jpg" class="w-full border px-4 py-3 rounded-lg outline-none"></div>
                    <div class="md:col-span-2 flex justify-end"><button type="submit" class="bg-brandTeal text-white font-bold px-8 py-3 rounded-lg hover:bg-brandGold transition-colors">Create Project</button></div>
                </form>
            </div>
            
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <% projects.forEach(proj => { %>
                    <div class="bg-white rounded-xl shadow p-6 relative">
                        <% if(proj.imageUrl) { %><img src="<%= proj.imageUrl.startsWith('http') ? proj.imageUrl : '/' + proj.imageUrl %>" class="w-full h-32 object-cover rounded-lg mb-4"><% } %>
                        <h3 class="font-bold text-lg"><%= proj.title %></h3>
                        <p class="text-sm text-gray-500 mb-4">Client: <%= proj.clientName %> | Status: <%= proj.status %></p>
                        
                        <div class="flex gap-4 mb-2">
                            <button onclick="document.getElementById('edit-form-<%= proj.id %>').classList.toggle('hidden')" class="text-blue-500 text-sm font-bold hover:underline">Edit</button>
                            <form action="/admin/projects/delete/<%= proj.id %>" method="POST" onsubmit="return confirm('Delete this project?')"><button class="text-red-500 text-sm font-bold hover:underline">Delete</button></form>
                        </div>

                        <!-- Edit Form (Hidden by default) -->
                        <form id="edit-form-<%= proj.id %>" action="/admin/projects/edit/<%= proj.id %>" method="POST" class="hidden mt-4 pt-4 border-t border-gray-200 space-y-3">
                            <div><label class="block text-xs font-bold text-gray-700">Title</label><input type="text" name="title" value="<%= proj.title %>" class="w-full border px-2 py-1 rounded outline-none text-sm"></div>
                            <div><label class="block text-xs font-bold text-gray-700">Client</label><input type="text" name="clientName" value="<%= proj.clientName %>" class="w-full border px-2 py-1 rounded outline-none text-sm"></div>
                            <div><label class="block text-xs font-bold text-gray-700">Status</label>
                                <select name="status" class="w-full border px-2 py-1 rounded outline-none text-sm">
                                    <option value="Planning" <%= proj.status === 'Planning' ? 'selected' : '' %>>Planning</option>
                                    <option value="Construction" <%= proj.status === 'Construction' ? 'selected' : '' %>>Construction</option>
                                    <option value="Completed" <%= proj.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                                </select>
                            </div>
                            <div><label class="block text-xs font-bold text-gray-700">Progress (%)</label><input type="number" name="progress" value="<%= proj.progress %>" class="w-full border px-2 py-1 rounded outline-none text-sm"></div>
                            <div><label class="block text-xs font-bold text-gray-700">Manager</label><input type="text" name="managerName" value="<%= proj.managerName %>" class="w-full border px-2 py-1 rounded outline-none text-sm"></div>
                            <div><label class="block text-xs font-bold text-gray-700">Image URL</label><input type="text" name="imageUrl" value="<%= proj.imageUrl %>" class="w-full border px-2 py-1 rounded outline-none text-sm"></div>
                                                        <div><label class="block text-xs font-bold text-gray-700">Category</label>
                                <select name="category" class="w-full border px-2 py-1 rounded outline-none text-sm">
                                    <option value="residential" <%= proj.category === 'residential' ? 'selected' : '' %>>Residential</option>
                                    <option value="commercial" <%= proj.category === 'commercial' ? 'selected' : '' %>>Commercial</option>
                                    <option value="interior" <%= proj.category === 'interior' ? 'selected' : '' %>>Interior</option>
                                    <option value="renovation" <%= proj.category === 'renovation' ? 'selected' : '' %>>Renovation</option>
                                </select>
                            </div>
                            <button type="submit" class="w-full bg-blue-500 text-white text-xs font-bold py-2 rounded hover:bg-blue-600">Save Changes</button></form>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- Tab: Blogs -->
        <div id="tab-blogs" class="tab-content hidden space-y-8">
            <div class="bg-white rounded-xl shadow p-6 border-l-4 border-blue-500">
                <h2 class="text-2xl font-bold mb-2">Publish New Blog Post</h2>
                <form action="/admin/blogs/new" method="POST" class="space-y-6">
                    <div><label class="block text-sm font-bold text-gray-700 mb-2">Blog Title</label><input type="text" name="title" required class="w-full border px-4 py-3 rounded-lg outline-none"></div>
                    <div><label class="block text-sm font-bold text-gray-700 mb-2">Cover Image URL</label><input type="url" name="imageUrl" placeholder="https://..." class="w-full border px-4 py-3 rounded-lg outline-none"></div>
                    <div><label class="block text-sm font-bold text-gray-700 mb-2">Content</label><textarea name="content" rows="6" required class="w-full border px-4 py-3 rounded-lg outline-none"></textarea></div>
                    <div class="flex justify-end"><button type="submit" class="bg-blue-600 text-white font-bold px-8 py-3 rounded-lg hover:bg-blue-700 transition-colors">Publish Blog</button></div>
                </form>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <% blogs.forEach(blog => { %>
                    <div class="bg-white rounded-xl shadow p-6">
                        <% if(blog.imageUrl) { %><img src="<%= blog.imageUrl %>" class="w-full h-32 object-cover rounded-lg mb-4"><% } %>
                        <h3 class="font-bold text-lg"><%= blog.title %></h3>
                        <p class="text-xs text-gray-400 mb-4"><%= new Date(blog.createdAt).toLocaleDateString() %></p>
                                                <div class="flex gap-4">
                            <button onclick="document.getElementById('edit-blog-<%= blog.id %>').classList.toggle('hidden')" class="text-blue-500 text-sm font-bold hover:underline">Edit</button>
                            <form action="/admin/blogs/delete/<%= blog.id %>" method="POST"><button class="text-red-500 text-sm font-bold hover:underline">Delete</button></form>
                        </div>
                        
                        <form id="edit-blog-<%= blog.id %>" action="/admin/blogs/edit/<%= blog.id %>" method="POST" class="hidden mt-4 pt-4 border-t border-gray-200 space-y-3">
                            <div><label class="block text-xs font-bold text-gray-700">Title</label><input type="text" name="title" value="<%= blog.title %>" class="w-full border px-2 py-1 rounded outline-none text-sm"></div>
                            <div><label class="block text-xs font-bold text-gray-700">Category</label><input type="text" name="category" value="<%= blog.category %>" class="w-full border px-2 py-1 rounded outline-none text-sm"></div>
                            <div><label class="block text-xs font-bold text-gray-700">Image URL</label><input type="text" name="imageUrl" value="<%= blog.imageUrl %>" class="w-full border px-2 py-1 rounded outline-none text-sm"></div>
                            <div><label class="block text-xs font-bold text-gray-700">Content</label><textarea name="content" rows="3" class="w-full border px-2 py-1 rounded outline-none text-sm"><%= blog.content %></textarea></div>
                            <button type="submit" class="w-full bg-blue-500 text-white text-xs font-bold py-2 rounded hover:bg-blue-600">Save Changes</button>
                        </form>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- Tab: Testimonials -->
        <div id="tab-testimonials" class="tab-content hidden space-y-8">
            <div class="bg-white rounded-xl shadow p-6 border-l-4 border-green-500">
                <h2 class="text-2xl font-bold mb-2">Add Client Testimonial</h2>
                <form action="/admin/testimonials/new" method="POST" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div><label class="block text-sm font-bold text-gray-700 mb-2">Author Name</label><input type="text" name="authorName" required class="w-full border px-4 py-3 rounded-lg outline-none"></div>
                        <div><label class="block text-sm font-bold text-gray-700 mb-2">Role/Company</label><input type="text" name="role" required class="w-full border px-4 py-3 rounded-lg outline-none"></div>
                    </div>
                    <div><label class="block text-sm font-bold text-gray-700 mb-2">Quote</label><textarea name="quote" rows="4" required class="w-full border px-4 py-3 rounded-lg outline-none"></textarea></div>
                    <div class="flex justify-end"><button type="submit" class="bg-green-600 text-white font-bold px-8 py-3 rounded-lg hover:bg-green-700 transition-colors">Save Testimonial</button></div>
                </form>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% testimonials.forEach(testi => { %>
                    <div class="bg-white rounded-xl shadow p-6">
                        <p class="text-gray-700 italic mb-4">"<%= testi.quote %>"</p>
                        <h3 class="font-bold text-sm"><%= testi.authorName %></h3>
                        <p class="text-xs text-gray-500 mb-4"><%= testi.role %></p>
                                                <div class="flex gap-4">
                            <button onclick="document.getElementById('edit-test-<%= testi.id %>').classList.toggle('hidden')" class="text-blue-500 text-sm font-bold hover:underline">Edit</button>
                            <form action="/admin/testimonials/delete/<%= testi.id %>" method="POST"><button class="text-red-500 text-sm font-bold hover:underline">Delete</button></form>
                        </div>
                        
                        <form id="edit-test-<%= testi.id %>" action="/admin/testimonials/edit/<%= testi.id %>" method="POST" class="hidden mt-4 pt-4 border-t border-gray-200 space-y-3">
                            <div><label class="block text-xs font-bold text-gray-700">Client Name</label><input type="text" name="authorName" value="<%= testi.authorName %>" class="w-full border px-2 py-1 rounded outline-none text-sm"></div>
                            <div><label class="block text-xs font-bold text-gray-700">Project / Role</label><input type="text" name="role" value="<%= testi.role %>" class="w-full border px-2 py-1 rounded outline-none text-sm"></div>
                            <div><label class="block text-xs font-bold text-gray-700">Quote</label><textarea name="quote" rows="3" class="w-full border px-2 py-1 rounded outline-none text-sm"><%= testi.quote %></textarea></div>
                            <button type="submit" class="w-full bg-blue-500 text-white text-xs font-bold py-2 rounded hover:bg-blue-600">Save Changes</button>
                        </form>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- Tab: CMS Content -->
        <div id="tab-content" class="tab-content hidden">
            <div class="bg-white rounded-xl shadow p-6">
                <h2 class="text-2xl font-bold mb-2">Global Text & Image CMS</h2>
                <p class="text-gray-500 mb-8">Update the headings, text, and hero image URLs across the website.</p>
                <form action="/admin/content/update" method="POST" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <% contents.forEach(item => { %>
                        <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
                            <label class="block text-xs font-bold text-brandTeal uppercase tracking-wider mb-2">Key: <%= item.key %></label>
                            <% if (item.value.length > 50 || item.key.includes('desc') || item.key.includes('text')) { %>
                                <textarea name="<%= item.key %>" rows="3" class="w-full px-3 py-2 border rounded focus:ring-2 focus:ring-brandGold outline-none"><%= item.value %></textarea>
                            <% } else { %>
                                <input type="text" name="<%= item.key %>" value="<%= item.value %>" class="w-full px-3 py-2 border rounded focus:ring-2 focus:ring-brandGold outline-none">
                            <% } %>
                        </div>
                    <% }) %>
                    </div>
                    
                    <div class="p-6 bg-yellow-50 rounded-lg border border-yellow-200 mb-6">
                        <h3 class="font-bold mb-2">Add New Key</h3>
                        <p class="text-sm text-gray-600 mb-4">You can dynamically add a new key to the database which can be used in EJS templates later.</p>
                        <p class="text-sm italic text-gray-500">Note: New keys can be added by developers directly in the DB or we can add a form for it here later.</p>
                    </div>

                    <div class="flex justify-end pt-4 sticky bottom-6">
                        <button type="submit" class="bg-brandTeal text-white font-bold px-8 py-4 rounded-xl hover:bg-brandGold transition-colors shadow-2xl text-lg w-full md:w-auto">Save All Content Changes</button>
                    </div>
                </form>
            </div>
        </div>

    </div>

</body>
</html>






