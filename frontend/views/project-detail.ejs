                    name: 'Contemporary Bedroom Suite', type: 'Interior', image: 'asset/idea_bedroom_1783442834138.jpg', 
                    gallery: ['asset/idea_bedroom_1783442834138.jpg', 'asset/project_interior1.jpg', 'asset/project_livingroom_1783442814598.jpg', 'asset/project_house1.jpg'], 
                    client: 'Private Residence', location: 'Hollywood Hills', year: '2023', area: '800 sq ft', duration: '6 weeks', 
                    desc: 'A serene master bedroom suite with custom built-in wardrobes, ambient lighting systems, and a spa-inspired ensuite bathroom. Designed for ultimate relaxation and comfort.', 
                    features: ['Custom built-in wardrobes', 'Ambient mood lighting', 'Spa-inspired ensuite', 'Soundproofed walls', 'Motorized blinds', 'Reading nook with skylight'], 
                    materials: ['Oak Hardwood', 'Linen Wallpaper', 'Brushed Nickel', 'Natural Stone', 'Acoustic Panels'], 
                    testimonial: 'It feels like sleeping in a five-star hotel every night. Absolutely perfect.' 
                },
                horizon: { 
                    name: 'Horizon Apartments', type: 'Residential', image: 'asset/project_house1.jpg', 
                    gallery: ['asset/project_house1.jpg', 'asset/card_residential_1783441988273.jpg', 'asset/project_interior1.jpg', 'asset/project_livingroom_1783442814598.jpg'], 
                    client: 'Horizon Developments', location: 'Venice Beach', year: '2024', area: '65,000 sq ft', duration: '24 months', 
                    desc: 'A boutique apartment complex featuring 48 luxury units with ocean views, a rooftop pool, and ground-floor retail spaces. Each unit features premium finishes and smart home technology.', 
                    features: ['48 luxury units', 'Rooftop infinity pool', 'Ocean-view balconies', 'Ground-floor retail', 'Concierge service', 'EV charging'], 
                    materials: ['Reinforced Concrete', 'Floor-to-Ceiling Glass', 'Engineered Wood', 'Composite Decking', 'Smart Lock Systems'], 
                    testimonial: 'The quality of these apartments sets a new standard for coastal living.' 
                }
            };

            const project = projectsDb[projectId] || projectsDb['skyline'];

            // Populate text fields
            document.title = `${project.name} | Indraprastha`;
            document.getElementById('pd-title').textContent = project.name;
            document.getElementById('pd-type').textContent = project.type;
            document.getElementById('pd-client').textContent = project.client;
            document.getElementById('pd-location').textContent = project.location;
            document.getElementById('pd-year').textContent = project.year;
            document.getElementById('pd-area').textContent = project.area;
            document.getElementById('pd-duration').textContent = project.duration;
            document.getElementById('pd-desc').textContent = project.desc;
            document.getElementById('pd-testimonial').textContent = project.testimonial;
            document.getElementById('pd-testi-name').textContent = project.client;
            document.getElementById('pd-testi-initial').textContent = project.client.charAt(0);
            
            // Set Hero Image
            document.getElementById('pd-hero-img').src = project.image;

            // Populate Gallery
            const galleryHtml = project.gallery.map(imgSrc => `
                <div class="h-64 rounded-xl overflow-hidden cursor-pointer group">
                    <img src="${imgSrc}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                </div>
            `).join('');
            document.getElementById('pd-gallery').innerHTML = galleryHtml;

            // Populate Features
            const featuresHtml = project.features.map(feature => `
                <li class="flex items-start gap-3 text-gray-600 dark:text-gray-400">
                    <svg class="w-5 h-5 text-brandGold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>${feature}</span>
                </li>
            `).join('');
            document.getElementById('pd-features').innerHTML = featuresHtml;

            // Populate Materials
            const materialsHtml = project.materials.map(mat => `
                <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-xs font-semibold rounded-full border border-gray-200 dark:border-gray-700">
                    ${mat}
                </span>
            `).join('');
            document.getElementById('pd-materials').innerHTML = materialsHtml;

            // Populate Related Projects (pick 3 different ones)
            const allKeys = Object.keys(projectsDb).filter(k => k !== projectId);
            // Shuffle
            const shuffledKeys = allKeys.sort(() => 0.5 - Math.random());
            const selectedKeys = shuffledKeys.slice(0, 3);
            
            const relatedHtml = selectedKeys.map(key => {
                const relProj = projectsDb[key];
                return `
                <a href="project-detail.html?id=${key}" class="group block bg-gray-50 dark:bg-darkBg rounded-2xl overflow-hidden shadow-sm hover:shadow-lg border border-gray-200 dark:border-gray-800 transition-all duration-300">
                    <div class="relative h-48 overflow-hidden">
                        <img src="${relProj.image}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                        <div class="absolute top-4 right-4 px-2 py-1 bg-white/90 dark:bg-black/90 backdrop-blur-sm text-[10px] font-bold uppercase tracking-wider text-brandTeal dark:text-brandGold rounded-full">${relProj.type}</div>
                    </div>
                    <div class="p-5">
                        <h3 class="text-lg font-bold mb-1 dark:text-white group-hover:text-brandGold transition-colors truncate">${relProj.name}</h3>
                        <p class="text-sm text-gray-500 dark:text-gray-400 truncate">${relProj.location}</p>
                    </div>
                </a>
                `;
            }).join('');
            document.getElementById('related-grid').innerHTML = relatedHtml;
        });
    </script>
</body>
</html>

