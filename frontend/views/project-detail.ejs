<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= project.title %> | Indraprastha</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: { brandTeal: '#1F363C', brandGold: '#C79F39', darkBg: '#0a0a0a', darkSurface: '#171717' },
                    fontFamily: { sans: ['Inter', 'sans-serif'], serif: ['Playfair Display', 'serif'] }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-gray-50 dark:bg-darkBg text-gray-900 dark:text-gray-100 font-sans transition-colors duration-300 pb-20 md:pb-0">

    <!-- Navbar -->
    <nav class="fixed top-0 w-full z-50 flex items-center justify-between px-6 py-4 bg-white/30 dark:bg-black/30 backdrop-blur-xl border-b border-gray-200/50 dark:border-white/10 transition-colors duration-300">
        <a href="/" class="flex-shrink-0"><img src="/asset/image/logo/logo_transparent.png" alt="Indraprastha Logo" class="h-10 md:h-14 object-contain transition-all"></a>
        <div class="hidden md:flex items-center gap-6">
            <a href="/" class="text-sm font-medium hover:text-brandGold transition-colors dark:text-gray-300">Home</a>
            <a href="/about.html" class="text-sm font-medium hover:text-brandGold transition-colors dark:text-gray-300">About Us</a>
            <a href="/projects.html" class="text-sm font-semibold hover:text-brandGold transition-colors text-brandTeal dark:text-white">Projects</a>
            <a href="/design-ideas.html" class="text-sm font-medium hover:text-brandGold transition-colors dark:text-gray-300">Design Ideas</a>
            <a href="/logo-upgrade.html" class="text-sm font-medium hover:text-brandGold transition-colors dark:text-gray-300">Branding</a>
            <a href="/reach-us.html" class="text-sm font-medium hover:text-brandGold transition-colors dark:text-gray-300">Contact</a>
        </div>
        <div class="flex items-center gap-4">
            <button id="theme-toggle" class="p-2 rounded-full bg-white/20 dark:bg-black/20 hover:bg-white/40 dark:hover:bg-black/40 transition-colors"><svg id="theme-toggle-light-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4.22 4.22a1 1 0 011.415 0l.708.708a1 1 0 01-1.414 1.414l-.708-.708a1 1 0 010-1.414zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM14.93 15.637a1 1 0 010 1.414l-.707.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM10 18a1 1 0 01-1-1v-1a1 1 0 112 0v1a1 1 0 01-1 1zm-4.22-4.22a1 1 0 01-1.415 0l-.708-.708a1 1 0 011.414-1.414l.708.708a1 1 0 010 1.414zM2 10a1 1 0 011-1h1a1 1 0 110 2H3a1 1 0 01-1-1zm3.07-5.637a1 1 0 010-1.414l.707-.707a1 1 0 011.414 1.414l-.707.707a1 1 0 01-1.414 0zM10 5a5 5 0 100 10 5 5 0 000-10z" fill-rule="evenodd" clip-rule="evenodd"></path></svg><svg id="theme-toggle-dark-icon" class="hidden w-5 h-5 text-gray-800" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg></button>
            <a href="/login.html" class="hidden md:inline-block px-5 py-2 rounded-full border border-gray-900 dark:border-white text-sm font-semibold hover:bg-gray-900 hover:text-white dark:hover:bg-white dark:hover:text-black transition-all">Login</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="relative pt-40 pb-32 bg-brandTeal text-white overflow-hidden">
        <div class="absolute inset-0 opacity-40">
            <img src="<%= project.bannerImageUrl || (project.imageUrl || '/asset/hero_building_1783441971426.jpg') %>" class="w-full h-full object-cover">
            <div class="absolute inset-0 bg-gradient-to-t from-brandTeal via-transparent to-transparent"></div>
        </div>
        <div class="container mx-auto px-6 relative z-10">
            <a href="/projects.html" class="inline-flex items-center gap-2 text-sm text-brandGold hover:text-white transition-colors mb-6 uppercase tracking-widest font-bold">
                &larr; Back to Projects
            </a>
            <h1 class="text-5xl md:text-7xl font-serif mb-4 leading-tight"><%= project.title %></h1>
            <span class="inline-block px-4 py-1 border border-brandGold/50 rounded-full text-sm font-medium tracking-wider bg-black/20 backdrop-blur-sm uppercase"><%= project.category || 'residential' %></span>
        </div>
    </header>

    <!-- Project Info Bar -->
    <section class="py-8 bg-white dark:bg-darkSurface shadow-md relative z-20 transition-colors">
        <div class="container mx-auto px-6">
            <div class="grid grid-cols-2 md:grid-cols-5 gap-6 text-sm divide-x divide-gray-200 dark:divide-gray-800">
                <div class="px-4">
                    <span class="block text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wider text-xs font-bold">Client</span>
                    <strong class="text-gray-900 dark:text-white text-base"><%= project.clientName %></strong>
                </div>
                <div class="px-4">
                    <span class="block text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wider text-xs font-bold">Location</span>
                    <strong class="text-gray-900 dark:text-white text-base"><%= project.location || 'Not Specified' %></strong>
                </div>
                <div class="px-4">
                    <span class="block text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wider text-xs font-bold">Year</span>
                    <strong class="text-gray-900 dark:text-white text-base"><%= project.year || 'Not Specified' %></strong>
                </div>
                <div class="px-4">
                    <span class="block text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wider text-xs font-bold">Area</span>
                    <strong class="text-gray-900 dark:text-white text-base"><%= project.area || 'Not Specified' %></strong>
                </div>
                <div class="px-4 hidden md:block">
                    <span class="block text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wider text-xs font-bold">Duration</span>
                    <strong class="text-gray-900 dark:text-white text-base"><%= project.duration || 'Not Specified' %></strong>
                </div>
            </div>
        </div>
    </section>

    <!-- Project Details -->
    <section class="py-20 bg-gray-50 dark:bg-darkBg transition-colors">
        <div class="container mx-auto px-6">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
                
                <!-- Main Content (Left 2/3) -->
                <div class="lg:col-span-2 space-y-12">
                    <!-- About -->
                    <div>
                        <h2 class="text-3xl font-bold mb-6 dark:text-white">About This Project</h2>
                        <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed mb-6 whitespace-pre-line">
                            <%= project.description || 'No description available for this project.' %>
                        </p>
                    </div>

                    <!-- 360 Virtual Tour -->
                    <div>
                        <div class="flex items-center justify-between mb-6">
                            <h3 class="text-2xl font-bold dark:text-white flex items-center gap-2">
                                <svg class="w-6 h-6 text-brandGold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                                360&deg; Virtual Tour
                            </h3>
                            <span class="text-xs font-bold text-white bg-brandGold px-2 py-1 rounded uppercase tracking-wider">Premium Feature</span>
                        </div>
                        <div class="w-full h-80 sm:h-96 rounded-2xl bg-gray-200 dark:bg-gray-800 border border-gray-300 dark:border-gray-700 relative overflow-hidden group cursor-move">
                            <img src="<%= project.virtualTourUrl || '/asset/idea_bedroom_1783442834138.jpg' %>" class="w-[120%] h-[120%] object-cover absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 transition-transform duration-[10s] group-hover:-translate-x-[40%]">
                            
                            <div class="absolute inset-0 bg-black/20 flex flex-col items-center justify-center pointer-events-none">
                                <div class="w-16 h-16 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center border border-white/50 mb-3 group-hover:scale-110 transition-transform">
                                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>
                                </div>
                                <span class="text-white font-bold tracking-widest uppercase text-sm drop-shadow-md">Drag to explore</span>
                            </div>
                        </div>
                    </div>

                    <!-- Gallery Grid -->
                    <% if (project.gallery && project.gallery.length > 0) { %>
                    <div>
                        <h3 class="text-2xl font-bold mb-6 dark:text-white">Project Gallery</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <% project.gallery.forEach(img => { %>
                                <% if(img && img.trim() !== '') { %>
                                <div class="h-64 rounded-xl overflow-hidden cursor-pointer group">
                                    <img src="<%= img %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                                </div>
                                <% } %>
                            <% }) %>
                        </div>
                    </div>
                    <% } %>
                </div>

                <!-- Sidebar (Right 1/3) -->
                <div class="space-y-10">
                    <!-- Features -->
                    <% if (project.keyFeatures && project.keyFeatures.length > 0) { %>
                    <div class="p-8 rounded-2xl bg-white dark:bg-darkSurface border border-gray-100 dark:border-gray-800 shadow-lg">
                        <h3 class="text-xl font-bold mb-6 dark:text-white border-b border-gray-100 dark:border-gray-800 pb-4">Key Features</h3>
                        <ul class="space-y-4">
                            <% project.keyFeatures.forEach(f => { %>
                                <% if(f && f.trim() !== '') { %>
                                <li class="flex items-start gap-3 text-gray-600 dark:text-gray-400">
                                    <svg class="w-5 h-5 text-brandGold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                                    <span><%= f %></span>
                                </li>
                                <% } %>
                            <% }) %>
                        </ul>
                    </div>
                    <% } %>

                    <!-- Materials -->
                    <% if (project.materialsUsed && project.materialsUsed.length > 0) { %>
                    <div class="p-8 rounded-2xl bg-white dark:bg-darkSurface border border-gray-100 dark:border-gray-800 shadow-lg">
                        <h3 class="text-xl font-bold mb-6 dark:text-white border-b border-gray-100 dark:border-gray-800 pb-4">Materials Used</h3>
                        <div class="flex flex-wrap gap-2">
                            <% project.materialsUsed.forEach(m => { %>
                                <% if(m && m.trim() !== '') { %>
                                <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-xs font-semibold rounded-full border border-gray-200 dark:border-gray-700">
                                    <%= m %>
                                </span>
                                <% } %>
                            <% }) %>
                        </div>
                    </div>
                    <% } %>

                    <!-- Testimonial -->
                    <% if (project.clientQuote && project.clientQuote.trim() !== '') { %>
                    <div class="p-8 rounded-2xl bg-brandTeal text-white relative">
                        <div class="text-5xl text-brandGold opacity-30 absolute top-4 left-4 font-serif">"</div>
                        <p class="relative z-10 italic text-lg leading-relaxed mb-6 mt-4"><%= project.clientQuote %></p>
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-full bg-brandGold flex items-center justify-center font-bold text-brandTeal text-sm">
                                <%= project.clientName ? project.clientName.charAt(0).toUpperCase() : 'C' %>
                            </div>
                            <div>
                                <strong class="block text-sm"><%= project.clientName %></strong>
                                <span class="text-xs text-brandGold">Project Owner</span>
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>

            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-darkBg text-gray-400 py-20 border-t border-gray-800">
        <div class="container mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12 text-center md:text-left mb-16">
            <div class="flex flex-col items-center md:items-start"><h4 class="text-white font-bold mb-6 tracking-widest">CONTACT US</h4><p class="mb-2">1428 West Elm Street, Suite 204</p><p class="mb-2">Los Angeles, CA 90026</p><p class="mb-2">Phone: (323) 555-7821</p><p>Email: hello@indraprasthaconstruction.com</p></div>
            <div class="flex flex-col items-center justify-center"><img src="/asset/image/logo/logo_transparent.png" alt="Indraprastha Logo" class="h-20 object-contain mb-4"><h3 class="text-white text-xl font-bold tracking-widest mb-4">INDRAPRASTHA</h3><p class="text-sm text-center max-w-xs">Building modern spaces with precision, quality, and lasting value.</p>
                <div class="flex gap-5 mt-6">
                    <a href="#" class="w-9 h-9 rounded-full border border-gray-600 flex items-center justify-center text-gray-400 hover:text-brandGold hover:border-brandGold transition-colors" aria-label="Facebook"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg></a>
                    <a href="#" class="w-9 h-9 rounded-full border border-gray-600 flex items-center justify-center text-gray-400 hover:text-brandGold hover:border-brandGold transition-colors" aria-label="Twitter"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg></a>
                    <a href="#" class="w-9 h-9 rounded-full border border-gray-600 flex items-center justify-center text-gray-400 hover:text-brandGold hover:border-brandGold transition-colors" aria-label="Instagram"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" /></svg></a>
                </div>
            </div>
            <div class="flex flex-col items-center md:items-end"><h4 class="text-white font-bold mb-6 tracking-widest">OFFICE HOURS</h4><p class="mb-1 text-white">MON-FRI</p><p class="mb-4">8:30 AM - 6:00 PM</p><p class="mb-1 text-white">SAT-SUN</p><p>Closed</p></div>
        </div>
        <div class="text-center text-sm border-t border-gray-800 pt-8">&copy; 2026 Indraprastha Construction. All Rights Reserved.</div>
    </footer>

    <!-- Mobile Bottom Navigation -->
    <nav class="md:hidden fixed bottom-0 left-0 w-full bg-white/70 dark:bg-black/70 backdrop-blur-2xl border-t border-gray-200/50 dark:border-white/10 z-50 flex justify-around items-center pb-safe pt-2 px-2 shadow-[0_-10px_40px_rgba(0,0,0,0.05)] transition-colors duration-300">
        <a href="/" class="flex flex-col items-center p-2 text-gray-500 dark:text-gray-400"><svg class="w-6 h-6 mb-1" fill="currentColor" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg><span class="text-[10px]">Home</span></a>
        <a href="/projects.html" class="flex flex-col items-center p-2 text-brandTeal dark:text-brandGold"><svg class="w-6 h-6 mb-1" fill="currentColor" viewBox="0 0 24 24"><path d="M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z"/></svg><span class="text-[10px] font-bold">Projects</span></a>
        <a href="/logo-upgrade.html" class="flex flex-col items-center p-2 text-gray-500 dark:text-gray-400"><svg class="w-6 h-6 mb-1" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l-5.5 9h11z"/><circle cx="17.5" cy="17.5" r="4.5"/><path d="M3 13.5h8v8H3z"/></svg><span class="text-[10px]">Branding</span></a>
        <a href="/login.html" class="flex flex-col items-center p-2 text-gray-500 dark:text-gray-400"><svg class="w-6 h-6 mb-1" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg><span class="text-[10px]">Login</span></a>
    </nav>
    <script src="/js/main.js"></script>

</body>
</html>
