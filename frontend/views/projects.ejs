    </nav>
    <script src="js/main.js"></script>

    <!-- Filter JS -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const filterBtns = document.querySelectorAll('.filter-btn');
            const projectCards = document.querySelectorAll('.project-card');

            filterBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    // Update active button styles
                    filterBtns.forEach(b => {
                        b.classList.remove('bg-brandTeal', 'text-white', 'border-brandTeal', 'dark:bg-brandGold', 'dark:text-brandTeal', 'dark:border-brandGold');
                        b.classList.add('border-gray-300', 'text-gray-600', 'dark:border-gray-700', 'dark:text-gray-400');
                    });
                    
                    btn.classList.remove('border-gray-300', 'text-gray-600', 'dark:border-gray-700', 'dark:text-gray-400');
                    btn.classList.add('bg-brandTeal', 'text-white', 'border-brandTeal', 'dark:bg-brandGold', 'dark:text-brandTeal', 'dark:border-brandGold');

                    // Filter cards
                    const filterValue = btn.getAttribute('data-filter');
                    
                    projectCards.forEach(card => {
                        if (filterValue === 'all' || card.getAttribute('data-category') === filterValue) {
                            card.style.display = 'block';
                            setTimeout(() => {
                                card.style.opacity = '1';
                                card.style.transform = 'scale(1)';
                            }, 50);
                        } else {
                            card.style.opacity = '0';
                            card.style.transform = 'scale(0.95)';
                            setTimeout(() => {
                                card.style.display = 'none';
                            }, 300);
                        }
                    });
                });
            });
        });
    </script>
</body>
