                    <% projects.forEach(p => { %>
                        <a href="/project-detail.html" class="project-card group block relative rounded-2xl overflow-hidden bg-gray-50 dark:bg-darkSurface shadow hover:shadow-2xl transition-all" data-category="<%= p.category || 'residential' %>">
                            <div class="h-64 overflow-hidden">
                                <img src="<%= p.imageUrl || 'https://via.placeholder.com/600x400?text=Project+Image' %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                            </div>
                            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-6">
                                <span class="inline-block px-3 py-1 bg-brandGold text-brandTeal text-xs font-bold rounded-full mb-3 self-start"><%= p.status %></span>
                                <h3 class="text-2xl font-bold text-white mb-1"><%= p.title %></h3>
                                <p class="text-gray-300 text-sm"><%= p.clientName %></p>
                            </div>
                        </a>
                    <% }) %>
                <% } else { %>
                    <!-- Fallback Previous Projects -->
                    <a href="/project-detail.html" class="project-card group block relative rounded-2xl overflow-hidden bg-gray-50 dark:bg-darkSurface shadow hover:shadow-2xl transition-all" data-category="commercial">
                        <div class="h-64 overflow-hidden">
                            <img src="asset/image/commercial/card_commercial.jpg" alt="Project 1" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                        </div>
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-6">
                            <span class="inline-block px-3 py-1 bg-brandGold text-brandTeal text-xs font-bold rounded-full mb-3 self-start">Completed</span>
                            <h3 class="text-2xl font-bold text-white mb-1">The Skyline Elite</h3>
                            <p class="text-gray-300 text-sm">Commercial Complex &bull; New Delhi</p>
                        </div>
                    </a>
                    
                    <a href="/project-detail.html" class="project-card group block relative rounded-2xl overflow-hidden bg-gray-50 dark:bg-darkSurface shadow hover:shadow-2xl transition-all" data-category="residential">
                        <div class="h-64 overflow-hidden">
                            <img src="asset/image/residential/idea_bathroom.jpg" alt="Project 2" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                        </div>
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-6">
                            <span class="inline-block px-3 py-1 bg-brandTeal text-brandGold border border-brandGold text-xs font-bold rounded-full mb-3 self-start">In Progress</span>
                            <h3 class="text-2xl font-bold text-white mb-1">Oasis Green Villas</h3>
                            <p class="text-gray-300 text-sm">Luxury Residential &bull; Gurugram</p>
                        </div>
                    </a>
                    
                    <a href="/project-detail.html" class="project-card group block relative rounded-2xl overflow-hidden bg-gray-50 dark:bg-darkSurface shadow hover:shadow-2xl transition-all" data-category="commercial">
                        <div class="h-64 overflow-hidden">
                            <img src="asset/image/commercial/idea_bedroom.jpg" alt="Project 3" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                        </div>
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-6">
                            <span class="inline-block px-3 py-1 bg-brandTeal text-brandGold border border-brandGold text-xs font-bold rounded-full mb-3 self-start">In Progress</span>
